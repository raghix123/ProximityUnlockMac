<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bluetooth permission descriptions (required by App Store / iOS) -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ProximityUnlock uses Bluetooth to advertise your iPhone's presence so your Mac can detect when you're nearby and unlock automatically.</string>

    <!-- Push notification permission is requested at runtime for unlock confirmations -->
    <!-- No special plist key required — we request via UNUserNotificationCenter at launch -->

    <!-- Background Bluetooth peripheral advertising -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
    </array>

    <!-- App transport security (no remote networking used) -->
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>

    <key>UILaunchScreen</key>
    <dict/>
</dict>
</plist>
